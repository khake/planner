# Supabase – คัดลอกไปที่ .env.local และใส่ค่าจริง (อย่า commit .env.local)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# สำหรับรัน migration สร้างตาราง (ใช้กับ npm run db:migrate)
# ใส่รหัสผ่าน Postgres จริงแทน [YOUR-PASSWORD]
# DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.your-project-ref.supabase.co:5432/postgres"

# Simple app-wide login (ทุกคนใช้ user/password ชุดเดียวกัน)
APP_LOGIN_USER=your-login-user
APP_LOGIN_PASSWORD=your-strong-password

